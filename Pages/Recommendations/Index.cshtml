@page
@model PersonalStylistIA.Pages.Recommendations.IndexModel
@{
    ViewData["Title"] = "Recomendações de Estilo IA";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<!-- Importa o CSS global da página -->
<link rel="stylesheet" href="~/css/recommendations.css" asp-append-version="true" />

<div class="recommendations-container">
    <header class="recommendation-header">
        <h1>📝 Recomendações de Estilo IA</h1>
        <p>Descreva a ocasião e receba sugestões personalizadas</p>
    </header>

    <!-- FORMULÁRIO DE INPUT -->
    <form method="post" class="recommendation-form">
        <div class="input-section">
            <textarea asp-for="UserPrompt"
                      placeholder="Ex: Look para formatura noturna, roupa casual para date no parque..."
                      maxlength="500"
                      rows="4"></textarea>
            <span asp-validation-for="UserPrompt" class="text-danger"></span>

            <div class="input-options">
                <select name="EstiloSelecionado">
                    <option value="Casual">Estilo: Casual</option>
                    <option value="Formal">Estilo: Formal</option>
                    <option value="Esportivo">Estilo: Esportivo</option>
                </select>

                <button type="submit" class="generate-btn" disabled="@Model.IsLoading">
                    @if (Model.IsLoading)
                    {
                        <span>⏳ Gerando...</span>
                    }
                    else
                    {
                        <span>✨ Gerar Recomendações</span>
                    }
                </button>
            </div>
        </div>
    </form>

    <!-- ESTADOS DINÂMICOS -->
    <div class="results-container">
        @if (Model.IsLoading)
        {
            <div class="loading-state">
                <div class="spinner"></div>
                <p>Analisando seu estilo...</p>
            </div>
        }
        else if (Model.HasError)
        {
            <div class="error-state">
                <div class="error-icon">⚠️</div>
                <p>@Model.ErrorMessage</p>
                <button class="retry-btn" onclick="location.reload()">Tentar novamente</button>
            </div>
        }
        else if (!string.IsNullOrEmpty(Model.Recommendation))
        {
            <div class="recommendation-card modern-layout">
                <div class="card-header">
                    <div class="header-badge">
                        <span class="badge-icon">🎯</span>
                        <span class="badge-text">Recomendação Personalizada</span>
                    </div>
                    <div class="card-actions">
                        <button type="button" class="action-btn copy-btn" title="Copiar recomendação" onclick="copyRecommendation()">
                            <span class="btn-icon">📋</span>
                            <span class="btn-text">Copiar</span>
                        </button>
                        <button type="button" class="action-btn save-btn" title="Salvar nos favoritos">
                            <span class="btn-icon">💾</span>
                            <span class="btn-text">Salvar</span>
                        </button>
                    </div>
                </div>

                <div class="recommendation-content">
                    <div class="content-header">
                        <h3>✨ Seu Look Ideal</h3>
                        <div class="divider-small"></div>
                    </div>

                    <div class="recommendation-text">
                        <div class="simple-recommendation">
                            <p>@Model.Recommendation</p>
                        </div>
                    </div>
                </div>

                <div class="card-footer">
                    <div class="footer-info">
                        <span class="info-icon">🕒</span>
                        <span class="info-text">Gerado agora</span>
                    </div>
                    <div class="footer-actions">
                        <a href="/Recommendations" class="outline-btn">
                            <span class="btn-icon">🔄</span>
                            <span class="btn-text">Nova Recomendação</span>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Copiar recomendação
        function copyRecommendation() {
            const text = document.querySelector('.simple-recommendation')?.innerText;
            if (text) {
                navigator.clipboard.writeText(text)
                    .then(() => alert('Recomendação copiada! 📋'))
                    .catch(() => alert('Erro ao copiar texto.'));
            }
        }
    </script>
}
